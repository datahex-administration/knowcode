# ---- Supabase (from supabase.com > Project Settings > API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key: SERVER ONLY. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- MsgHex (WhatsApp) — Dashboard > Settings > Developers ----
MSGHEX_API_SECRET=dh_live_xxxxxxxx
MSGHEX_SESSION_ID=your-device-session-id
# Message sent to applicant on new application ({{name}} replaced)
MSGHEX_APPLY_MESSAGE=Hi {{name}}, your KnowCode Academy application is received. Our team will contact you shortly.
